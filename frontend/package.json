		"globals": "^15.0.0",
		"prettier": "^3.1.0",
		"prettier-plugin-svelte": "^3.1.0",
		"svelte": "^5.0.0",
		"svelte-check": "^3.6.0",
		"tslib": "^2.6.0",
		"typescript": "^5.3.0",
		"typescript-eslint": "^8.0.0",
		"vite": "^5.0.0",
