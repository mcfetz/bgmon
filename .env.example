# ── Core (required) ─────────────────────────────────────────────────────
BGMON_SECRET_KEY=change-me-in-production
BGMON_DATABASE_URL=postgresql://bgmon:bgmon@localhost:5432/bgmon
BGMON_PUBLIC_BASE_URL=https://bgmon.example.com

# ── LibreLinkUp (required for CGM data) ─────────────────────────────────
BGMON_LIBRE_EMAIL=your-libre-email
BGMON_LIBRE_PASSWORD=your-libre-password
BGMON_LIBRE_REGION=EU2

# ── Twilio (optional — phone alarms) ────────────────────────────────────
BGMON_TWILIO_ACCOUNT_SID=AC...
BGMON_TWILIO_AUTH_TOKEN=...
BGMON_TWILIO_FROM_NUMBER=+49...
BGMON_TWILIO_NUMBERS=+49...
BGMON_TWILIO_RETRY_COUNT=3
BGMON_TWILIO_RETRY_DELAY_S=90

# ── VAPID (optional — Web-Push, generate with scripts/generate-vapid-keys.sh)
VAPID_PUBLIC_KEY=...
VAPID_PRIVATE_KEY=...
VAPID_SUBJECT=mailto:admin@example.com

# ── Bootstrap (optional — first-run admin user) ─────────────────────────
BGMON_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BGMON_BOOTSTRAP_ADMIN_PASSWORD=change-me

# ── InfluxDB (optional — secondary time-series storage) ─────────────────
#BGMON_INFLUXDB_URL=https://influxdb.example.com
#BGMON_INFLUXDB_TOKEN=your-influx-token
#BGMON_INFLUXDB_ORG=my-org
#BGMON_INFLUXDB_BUCKET=gluroo

# ── ML prediction (optional — bg-prediction-v1) ─────────────────────────
#BGMON_ML_ENABLED=true
#BGMON_ML_MODEL_PATH=backend/ml_models/bg_prediction_v1
#BGMON_ML_HORIZONS=30,60,120

# ── KI-Integration (optional — KE-Schätzung aus Text/Foto) ──────────────
#BGMON_LLM_BASE_URL=https://api.openai.com/v1
#BGMON_LLM_MODEL=gpt-4o
#BGMON_LLM_API_KEY=sk-...

# ── Scheduler (optional — disable standalone scheduler) ─────────────────
#BGMON_DISABLE_SCHEDULER=false

# ── Leader election (multi-instance tuning) ─────────────────────────────
BGMON_LEASE_TTL_S=30
BGMON_LEADER_RENEW_S=10
