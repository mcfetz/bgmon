# Core
BGMON_SECRET_KEY=change-me-in-production
BGMON_DATABASE_URL=postgresql://bgmon:bgmon@localhost:5432/bgmon
BGMON_PUBLIC_BASE_URL=https://bgmon.familie-heise.de

# InfluxDB (existing)
BGMON_INFLUXDB_URL=https://influxdb.familie-heise.de
BGMON_INFLUXDB_TOKEN=your-influx-token
BGMON_INFLUXDB_ORG=familie-heise.de
BGMON_INFLUXDB_BUCKET=gluroo

# LibreLinkUp
BGMON_LIBRE_EMAIL=post@mcfetz.de
BGMON_LIBRE_PASSWORD=your-libre-password
BGMON_LIBRE_REGION=EU2

# Twilio
BGMON_TWILIO_ACCOUNT_SID=AC...
BGMON_TWILIO_AUTH_TOKEN=...
BGMON_TWILIO_FROM_NUMBER=+49...
# Comma-separated list of allowed caller-ID numbers (for per-recipient routing)
BGMON_TWILIO_NUMBERS=+49...
BGMON_TWILIO_RETRY_COUNT=3
BGMON_TWILIO_RETRY_DELAY_S=90

# VAPID (generate with scripts/generate-vapid-keys.sh)
VAPID_PUBLIC_KEY=...
VAPID_PRIVATE_KEY=...
VAPID_SUBJECT=mailto:admin@familie-heise.de

# Bootstrap (first run only)
BGMON_BOOTSTRAP_ADMIN_EMAIL=admin@familie-heise.de
BGMON_BOOTSTRAP_ADMIN_PASSWORD=change-me

# Leader election
BGMON_LEASE_TTL_S=30
BGMON_LEADER_RENEW_S=10

# ML prediction (bg-prediction-v1)
#BGMON_ML_ENABLED=true
#BGMON_ML_MODEL_PATH=
#BGMON_ML_HORIZONS=60,120
